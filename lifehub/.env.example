# OneLife environment variables (copy to .env to override)
FLASK_ENV=production
SECRET_KEY=change-me-in-production
HOST=127.0.0.1
PORT=5000

# Database (use sqlite:///onelife.db for default instance folder)
DATABASE_URL=sqlite:///onelife.db

# Uploads (defaults to ./uploads)
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=50

# Debug (set to 1 in development only)
DEBUG=0

# Bearer token for the Health Connect Android companion app.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable the /api/health/ingest endpoint (returns 503).
# INGEST_TOKEN=
